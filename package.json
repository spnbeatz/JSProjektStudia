    "dotenv": "^17.4.2",
    "express": "~4.16.1",
    "express-session": "^1.19.0",
    "http-errors": "~1.6.3",
    "jade": "~1.11.0",
    "morgan": "~1.9.1",
    "mysql2": "^3.22.3",
    "nodemon": "^3.1.14",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "autoprefixer": "^10.5.0",
